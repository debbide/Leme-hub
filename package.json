{
  "name": "leme-hub",
  "private": true,
  "version": "0.1.4",
  "productName": "Leme Hub",
  "description": "Multi-port proxy splitting for desktop and server workflows.",
  "author": "debbide",
  "type": "module",
  "main": "desktop/electron-main.js",
  "scripts": {
    "start": "node app/server/index.js",
    "start:server": "node scripts/server.js",
    "prepare:icons": "node scripts/prepare-icons.js",
    "desktop:dev": "electron .",
    "build:desktop:win": "npm run prepare:icons && electron-builder --publish never --win nsis portable",
    "build:desktop:deb": "npm run prepare:icons && electron-builder --publish never --linux deb",
    "build:server": "pkg ./scripts/server.js --targets node20-linux-x64,node20-linux-arm64 --out-path dist/server",
    "dev": "node scripts/dev.js",
    "test": "node --test"
  },
  "dependencies": {
    "adm-zip": "^0.5.16",
    "axios": "^1.6.7",
    "socks-proxy-agent": "^8.0.3",
    "tar": "^7.5.13"
  },
  "devDependencies": {
    "@yao-pkg/pkg": "^6.6.0",
    "encoding": "^0.1.13",
    "electron": "^36.3.2",
    "electron-builder": "^26.0.12",
    "jimp": "^1.6.0",
    "png-to-ico": "^2.1.8"
  },
  "pkg": {
    "assets": [
      "public/**/*",
      "docs/**/*"
    ],
    "scripts": [
      "app/**/*.js",
      "scripts/**/*.js"
    ],
    "outputPath": "dist/server"
  },
  "build": {
    "appId": "com.leme.hub",
    "productName": "Leme Hub",
    "asar": true,
    "directories": {
      "output": "dist/desktop",
      "buildResources": "desktop/resources"
    },
    "artifactName": "${productName}-${version}-${os}-${arch}.${ext}",
    "files": [
      "app/**/*",
      "desktop/**/*",
      "public/**/*",
      "scripts/**/*",
      "package.json"
    ],
    "win": {
      "icon": "desktop/resources/icon.ico",
      "target": [
        "nsis"
      ]
    },
    "linux": {
      "icon": "desktop/resources/icon.png",
      "target": [
        "deb"
      ],
      "category": "Network"
    }
  }
}
