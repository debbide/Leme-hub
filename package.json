{
  "name": "leme-hub",
  "private": true,
  "version": "0.1.6",
  "productName": "Leme Hub",
  "description": "Multi-port proxy splitting for desktop and server workflows.",
  "author": {
    "name": "debbide",
    "email": "debbide@users.noreply.github.com"
  },
  "type": "module",
  "main": "desktop/electron-main.js",
  "scripts": {
    "start": "node app/server/index.js",
    "start:server": "node scripts/server.js",
    "prepare:icons": "node scripts/prepare-icons.js",
    "desktop:dev": "electron .",
    "build:desktop:win": "npm run prepare:icons && electron-builder --publish never --win zip",
    "build:desktop:deb": "npm run prepare:icons && electron-builder --publish never --linux deb",
    "build:server:bundle": "node scripts/build-server-bundle.mjs",
    "build:server": "npm run build:server:bundle && pkg ./dist/server/package.json --targets node20-linux-x64,node20-linux-arm64 --out-path dist/server",
    "dev": "node scripts/dev.js",
    "test": "node --test"
  },
  "dependencies": {
    "@maxmind/geoip2-node": "^6.3.4",
    "adm-zip": "^0.5.16",
    "axios": "^1.6.7",
    "socks-proxy-agent": "^8.0.3",
    "tar": "^7.5.13"
  },
  "devDependencies": {
    "@yao-pkg/pkg": "^6.6.0",
    "electron": "^36.3.2",
    "electron-builder": "^26.0.12",
    "encoding": "^0.1.13",
    "esbuild": "^0.25.2",
    "jimp": "^1.6.0",
    "png-to-ico": "^2.1.8"
  },
  "build": {
    "appId": "com.leme.hub",
    "productName": "Leme Hub",
    "asar": true,
    "directories": {
      "output": "dist/desktop",
      "buildResources": "desktop/resources"
    },
    "artifactName": "${productName}-${version}-${os}-${arch}.${ext}",
    "files": [
      "app/**/*",
      "desktop/**/*",
      "public/**/*",
      "scripts/**/*",
      "package.json"
    ],
    "win": {
      "icon": "desktop/resources/icon.ico",
      "target": [
        "zip"
      ]
    },
    "linux": {
      "icon": "desktop/resources/icon.png",
      "maintainer": "debbide <debbide@users.noreply.github.com>",
      "target": [
        "deb"
      ],
      "category": "Network"
    }
  }
}
